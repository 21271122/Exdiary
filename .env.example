# =====================================================
# DeepSeek API 配置 — 基于官方文档 api-docs.deepseek.com
# =====================================================
# 复制此文件为 .env 并填入你的 API Key
#
# Base URL: https://api.deepseek.com (OpenAI 兼容格式)
#
# 模型说明:
#   deepseek-v4-flash   支持 function calling，用于结构化提取
#   deepseek-v4-pro     推理增强，用于实验分析（不支持 function calling）
# =====================================================

DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_ANALYZE_MODEL=deepseek-v4-pro
PORT=5000
GUI=true
